{
  "name": "pantryplus",
  "version": "1.5.2",
  "scripts": {
    "start": "npx expo start --dev-client",
    "prebuild": "NODE_NO_WARNINGS=1 npx expo prebuild",
    "prebuild:clean": "NODE_NO_WARNINGS=1 npx expo prebuild --clean  # This will regenerate the native iOS files",
    "ios": "NODE_NO_WARNINGS=1 npx expo run:ios",
    "android": "NODE_NO_WARNINGS=1 npx expo run:android",
    "dev:ios": "eas build --platform ios --profile development --clear-cache --local",
    "preview:ios": "eas build --platform ios --profile preview --clear-cache",
    "prod:ios": "eas build --platform ios --profile prod --clear-cache",
    "publish:ios": "eas submit --platform ios",
    "update:preview": "node scripts/update.js preview",
    "update:prod": "node scripts/update.js prod",
    "version:patch": "./scripts/version.sh patch",
    "version:minor": "./scripts/version.sh minor",
    "killport": "sudo kill -9 $(sudo lsof -t -i :8081) # Do this if the Metro Bundler fails to start",
    "gettoken": "npx ts-node scripts/get-token.ts",
    "expoupdate": "node scripts/update.js",
    "maestro": "./scripts/maestro-tests.sh --screenshots current",
    "maestro:current": "./scripts/maestro-tests.sh --screenshots current all",
    "maestro:baseline": "./scripts/maestro-tests.sh --screenshots baseline all"
  },
  "dependencies": {
    "@aws-amplify/react-native": "^1.1.6",
    "@aws-amplify/rtn-web-browser": "^1.1.1",
    "@aws-amplify/ui-react-native": "^2.2.16",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/drawer": "^6.7.2",
    "@react-navigation/native": "6.1.9",
    "@react-navigation/stack": "6.3.20",
    "aws-amplify": "^6.6.7",
    "date-fns": "^4.1.0",
    "expo": "^54.0.33",
    "expo-application": "~7.0.8",
    "expo-asset": "~12.0.12",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-location": "~19.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "metro": "^0.83.1",
    "mobx": "^6.13.5",
    "mobx-react": "^9.1.1",
    "mobx-state-tree": "^6.0.1",
    "mst-persist": "^0.1.4",
    "pantryplus-api-client": "github:askewsoft/pantryPlusApiClient#v1.2.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-context-menu-view": "^1.19.0",
    "react-native-draggable-flatlist": "^4.0.1",
    "react-native-dropdown-picker": "^5.4.6",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-reanimated-carousel": "^3.5.1",
    "react-native-worklets": "0.8.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-swipeable-item": "^2.0.9"
  },
  "devDependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.535.0",
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "dotenv": "^16.4.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
